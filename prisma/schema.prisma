generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// Sprints (Iteraciones de trabajo)
model Sprint {
  id           String     @id @default(cuid())
  name         String     // Ej: "Sprint 1", "KickOff"
  goal         String?    @db.Text // Objetivo del Sprint
  startDate    DateTime?
  endDate      DateTime?
  status       String     @default("PLANNED") // "PLANNED", "ACTIVE", "COMPLETED"
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)

  tasks        Task[]
 

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Épicas (Grandes iniciativas que agrupan tareas)
model Epic {
  id           String     @id @default(cuid())
  name         String     // Ej: "Sistema de Autenticación"
  color        String     @default("bg-purple-500") // Para la etiqueta visual en la tarjeta
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)

  tasks        Task[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// --- TABLAS DE NEXTAUTH ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- MODELO DE USUARIO ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  
  // Relaciones para Tasky
  ownedSpaces         Taskyspace[] @relation("SpaceOwner")
  memberships         Member[]
  sentInvitations     Invitation[] @relation("SentInvitations") 
  receivedInvitations Invitation[] @relation("ReceivedInvitations") 
  
  // Tareas relacionadas
  assignedTasks       Task[]       @relation("TaskAssignee") // Tareas que tiene asignadas
  tasksSupported      Task[]       @relation("TaskSupport")  // Tareas donde es apoyo
  tasksAuthored       Task[]       @relation("TaskAuthor")   // Tareas que creó

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- MODELOS DE TASKY ---

model Taskyspace {
  id          String    @id @default(cuid())
  name        String
  privacy     String    // "Abierto" o "Privado"
  password    String?   
  
  ownerId     String
  owner       User      @relation("SpaceOwner", fields: [ownerId], references: [id])

  members     Member[]
  invitations Invitation[] 
  columns     Column[]      
  activities  ActivityType[]
  tasks       Task[]
  sprints     Sprint[]   
  epics       Epic[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Miembros de un equipo
model Member {
  id           String     @id @default(cuid())
  role         String     // "Administrador", "Miembro", "Solo Visor"
  
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, taskyspaceId])
}

// Columnas del Kanban 
model Column {
  id           String     @id @default(cuid())
  title        String     
  color        String?    @default("#10b981")
  order        Int        @default(0)
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)
  
  tasks        Task[]
}

// Tipos de actividades (Ej: Tarea, Historia, Error)
model ActivityType {
  id           String     @id @default(cuid())
  name         String
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)
  
  tasks        Task[]
}

// Tareas individuales (Las tarjetas)
model Task {
  id                 String        @id @default(cuid()) 
  title              String
  description        String?       @db.Text 
  order              Int           @default(0) 
  isCompleted        Boolean       @default(false)
  
  // --- NUEVOS CAMPOS DEL EXCEL (BACKLOG SPRINT) ---
  type               String?       @default("Task") // Task, Feature, Bug, Doc
  priority           String?       @default("Media") // Alta, Media, Baja
  effortHours        Float?        @default(0)       // Esfuerzo (hrs)
  dueDate            DateTime?     // Fecha objetivo
  isBlocked          Boolean       @default(false)   // Bloqueado (sí/no)
  dependencies       String?                         // Dependencias (Ej. "TK-01")
  acceptanceCriteria String?       @db.Text          // Criterios de aceptación
  prLink             String?                         // Link PR
  notes              String?       @db.Text          // Notas adicionales
  closedAt           DateTime?                       // Fecha de cierre
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // --- RELACIONES ---
  sprintId           String?
  sprint             Sprint?       @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  epicId      String?
  epic        Epic?      @relation(fields: [epicId], references: [id], onDelete: SetNull)

  taskyspaceId       String
  taskyspace         Taskyspace    @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)

  columnId           String        
  column             Column        @relation(fields: [columnId], references: [id], onDelete: Cascade)

  activityTypeId     String?
  activityType       ActivityType? @relation(fields: [activityTypeId], references: [id])

  assigneeId         String?       
  assignee           User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  supportId          String?
  support            User?         @relation("TaskSupport", fields: [supportId], references: [id], onDelete: SetNull)

  authorId           String?
  author             User?         @relation("TaskAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

// --- SISTEMA DE INVITACIONES ---
model Invitation {
  id             String     @id @default(cuid())
  role           String     
  status         String     @default("PENDIENTE") 
  
  taskyspaceId   String
  taskyspace     Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)
  
  inviterId      String
  inviter        User       @relation("SentInvitations", fields: [inviterId], references: [id])
  
  invitedUserId  String
  invitedUser    User       @relation("ReceivedInvitations", fields: [invitedUserId], references: [id])
  
  createdAt      DateTime   @default(now())
}